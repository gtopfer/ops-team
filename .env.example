# -----------------------------------------------------------------------------
# Meta / operacional do próprio ops-team
# -----------------------------------------------------------------------------
# Diretório local onde o api-integrator grava logs de chamadas
OPS_TEAM_API_LOG_DIR=./output/api-calls

# Se true, recusa executar qualquer query em endpoint não listado no catálogo
OPS_TEAM_STRICT_CATALOG=true

# Timezone para timestamps de parecer/CR (ex.: America/Sao_Paulo, UTC)
OPS_TEAM_TZ=America/Sao_Paulo
