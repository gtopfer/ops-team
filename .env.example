# =============================================================================
# ops-team — template de credenciais (read-only)
# =============================================================================
# COPIE este arquivo para .env (sem .example) e preencha apenas o que for usar.
# O .env REAL é ignorado pelo git (.gitignore). Nunca commitar .env com valores.
#
# Princípios:
# - Use credencial read-only sempre que o sistema suportar.
# - Nunca use chave de admin quando existe read-only para o mesmo dado.
# - Rotacione tokens periodicamente.
# - HTTPS sempre; certificado válido ou pinning documentado.
# - Se a API estiver em rede privada, conecte via VPN/bastion.
# =============================================================================


# -----------------------------------------------------------------------------
# Clouds
# -----------------------------------------------------------------------------
AWS_PROFILE=readonly
AWS_REGION=us-east-1
# alternativa a profile: chaves explícitas (evite, prefira SSO/aws-vault)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

GCP_SERVICE_ACCOUNT_JSON=/path/to/readonly-sa.json
GCP_PROJECT=

AZURE_TENANT_ID=
AZURE_SUBSCRIPTION_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

OCI_CONFIG_FILE=~/.oci/config
OCI_PROFILE=DEFAULT


# -----------------------------------------------------------------------------
# Orquestradores / virtualização
# -----------------------------------------------------------------------------
KUBECONFIG=~/.kube/config

PROXMOX_URL=
PROXMOX_TOKEN_ID=
PROXMOX_TOKEN_SECRET=

VCENTER_URL=
VCENTER_USER=
VCENTER_PASS=

NUTANIX_URL=
NUTANIX_USER=
NUTANIX_PASS=

OPENSTACK_AUTH_URL=
OPENSTACK_USER=
OPENSTACK_PASS=
OPENSTACK_PROJECT=
OPENSTACK_DOMAIN=Default


# -----------------------------------------------------------------------------
# Observabilidade
